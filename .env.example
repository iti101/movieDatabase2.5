# Required — The Movie Database (TMDB) API key
# Create one at: https://www.themoviedb.org/settings/api
VITE_TMDB_API_KEY=your_tmdb_api_key_here

# Required — NOVI education backend project ID
# Create a project on the NOVI backend and paste its ID here
VITE_NOVI_PROJECT_ID=your_novi_project_id_here

# Optional — override the default NOVI API host
# Default: https://novi-backend-api-wgsgz.ondigitalocean.app
# VITE_NOVI_API_BASE=https://novi-backend-api-wgsgz.ondigitalocean.app

# Optional — ISO 3166-1 alpha-2 country code for watch-provider results
# Falls back to the browser locale, then US
# VITE_WATCH_REGION=US
